{
  "uid": "ai-metrics",
  "title": "AI 서비스 메트릭",
  "tags": ["ai", "http", "db", "external", "batch"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "10s",
  "style": "dark",
  "panels": [
    {
      "id": 4,
      "title": "메뉴추천",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(ai_requests_total{endpoint=\"menu\",status=\"ok\"}[$__range]))",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": null }
        },
        {
          "expr": "sum(increase(ai_tokens_total{endpoint=\"menu\"}[$__range]))",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": null }
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["last"], "fields": "" },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 10000, "color": "orange" },
              { "value": 50000, "color": "red" }
            ]
          },
          "mappings": [
            {
              "options": { "match": "null", "result": { "text": "0" } },
              "type": "special"
            }
          ],
          "nullValueMode": "null as zero"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "A" },
            "properties": [
              { "id": "displayName", "value": "요청수" },
              { "id": "unit", "value": "none" },
              { "id": "decimals", "value": 0 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 100, "color": "orange" }, { "value": 500, "color": "red" }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "B" },
            "properties": [
              { "id": "displayName", "value": "토큰수" },
              { "id": "unit", "value": "short" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 10000, "color": "orange" }, { "value": 50000, "color": "red" }] } }
            ]
          }
        ]
      }
    },
