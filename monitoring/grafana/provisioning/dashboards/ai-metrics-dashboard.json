    },
    {
      "id": 11,
      "title": "AI 요청 수",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "label_replace(label_replace(sum(rate(ai_requests_total[5m])) by (endpoint, status), \"endpoint\", \"메뉴추천\", \"endpoint\", \"menu\"), \"endpoint\", \"가게추천\", \"endpoint\", \"places\")",
          "refId": "A",
          "legendFormat": "{{endpoint}} {{status}}",
          "datasource": { "type": "prometheus", "uid": null }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 2, "showPoints": "never" } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 12,
      "title": "AI 지연 p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "label_replace(label_replace(histogram_quantile(0.95, sum(rate(ai_request_duration_seconds_bucket[5m])) by (le, endpoint)), \"endpoint\", \"메뉴추천\", \"endpoint\", \"menu\"), \"endpoint\", \"가게추천\", \"endpoint\", \"places\")",
          "refId": "A",
          "legendFormat": "{{endpoint}}",
          "datasource": { "type": "prometheus", "uid": null }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 2, "showPoints": "never" } }
