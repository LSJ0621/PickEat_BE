    {
      "id": 1,
      "title": "DB 상태",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 4 },
      "targets": [
        { "expr": "avg(db_up)", "refId": "A", "datasource": { "type": "prometheus", "uid": null } }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "nullValueMode": "null as zero",
          "mappings": [
            {
              "options": { "match": "null", "result": { "text": "0" } },
              "type": "special"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.5, "color": "orange" },
              { "value": 0.99, "color": "green" }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["last"] } }
    },
    {
      "id": 2,
      "title": "HTTP 5xx 비율",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": null }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "nullValueMode": "null as zero",
          "mappings": [
            {
              "options": { "match": "null", "result": { "text": "0" } },
              "type": "special"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "orange" },
              { "value": 0.05, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["last"] } }
    },
    {
      "id": 3,
      "title": "외부 API 오류/타임아웃 비율",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(external_api_requests_total{status_group=~\"5xx|4xx|429|timeout\"}[5m])) / clamp_min(sum(rate(external_api_requests_total[5m])), 1)",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": null }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "nullValueMode": "null as zero",
          "mappings": [
            {
              "options": { "match": "null", "result": { "text": "0" } },
              "type": "special"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "orange" },
              { "value": 0.05, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["last"] } }
    },
    {
      "id": 5,
      "title": "HTTP 요청 수 (route/status)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (route, status)",
          "refId": "A",
          "legendFormat": "{{route}} {{status}}",
          "datasource": { "type": "prometheus", "uid": null }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 2, "showPoints": "never", "nullValue": "null as zero" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "title": "HTTP 지연 p95 (route)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "refId": "A",
          "legendFormat": "{{route}}",
          "datasource": { "type": "prometheus", "uid": null }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 2, "showPoints": "never", "nullValue": "null as zero" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } }
    },
