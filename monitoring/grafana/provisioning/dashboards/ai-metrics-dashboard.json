  "version": 3,
  "refresh": "10s",
  "style": "dark",
  "panels": [
    {
      "id": 4,
      "title": "메뉴추천",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "floor(sum(increase(ai_requests_total{endpoint=\"menu\",status=\"ok\"}[max($__range, 1m)])) or vector(0))",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": null }
        },
        {
          "expr": "floor(sum(increase(ai_tokens_total{endpoint=\"menu\"}[max($__range, 1m)])) or vector(0))",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": null }
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["last"], "fields": "" },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 10000, "color": "orange" },
              { "value": 50000, "color": "red" }
            ]
          },
          "mappings": [
            {
              "options": { "match": "null", "result": { "text": "0" } },
              "type": "special"
            }
          ],
          "nullValueMode": "null as zero"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "A" },
            "properties": [
              { "id": "displayName", "value": "요청수" },
              { "id": "unit", "value": "none" },
              { "id": "decimals", "value": 0 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 100, "color": "orange" }, { "value": 500, "color": "red" }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "B" },
            "properties": [
              { "id": "displayName", "value": "토큰수" },
              { "id": "unit", "value": "short" },
