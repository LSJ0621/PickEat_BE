    {
      "id": 2,
      "title": "HTTP 5xx 비율",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": null }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "nullValueMode": "null as zero",
          "mappings": [
            {
              "options": { "match": "null", "result": { "text": "0" } },
              "type": "special"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "orange" },
              { "value": 0.05, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["last"] } }
    },
