# Application
NODE_ENV=
PORT=
CORS_ORIGIN=                                 # 콤마 구분 멀티 도메인 지원 (e.g. https://a.com,https://b.com)
APP_URL=
FRONTEND_URL=                                # 이메일 링크용 프론트엔드 URL (optional, default: https://pickeat.com)

# Database (Postgres)
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_SYNCHRONIZE=

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=

# Email (for verification)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_SECURE=
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_MENU_MODEL=
OPENAI_PREFERENCE_MODEL=
OPENAI_PLACES_MODEL=
OPENAI_VALIDATION_MODEL=

# Kakao API
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_REDIRECT_URI=

# Google API
GOOGLE_API_KEY=
GOOGLE_CSE_CX=
GOOGLE_GEMINI_API_KEY=
GEMINI_LOG_VERBOSITY=               # Options: minimal | normal | debug (default: normal)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=

# Admin User (optional, for initial seeding)
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_ROLE=

# AWS S3
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_S3_BUCKET_PUBLIC=                    # 'true' or 'false' - 버킷이 public-read인지 여부

# Discord Webhook (버그 리포트 알림)
DISCORD_BUG_REPORT_WEBHOOK_URL=
DISCORD_SCHEDULER_WEBHOOK_URL=              # Optional: 스케줄러 실패 알림 (미설정 시 DISCORD_BUG_REPORT_WEBHOOK_URL 사용)

# Scheduler Cron Expressions (optional, defaults are production values)
CRON_PREFERENCES_BATCH_SUBMIT=
CRON_PREFERENCES_RETRY_BATCH=
CRON_PREFERENCES_BATCH_RESULT=
CRON_RATING_AGGREGATE=
CRON_NOTIFICATION_PUBLISH=

# Address Search
ADDRESS_SEARCH_PROVIDER=                     # Options: kakao | google (optional)

