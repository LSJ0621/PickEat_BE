<!DOCTYPE html>
<html lang="{{lang}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{pageTitle}}</title>
  <!--[if mso]>
  <style type="text/css">
    body, table, td {font-family: Arial, sans-serif !important;}
  </style>
  <![endif]-->
</head>
<body style="margin: 0; padding: 0; background-color: #020617; font-family: 'Inter', 'Noto Sans KR', 'Pretendard Variable', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #020617;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <!-- Main Container -->
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="max-width: 600px; background-color: rgba(255, 255, 255, 0.05); border-radius: 32px; border: 1px solid rgba(255, 255, 255, 0.1); box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);">

          <!-- Header with Logo -->
          <tr>
            <td align="center" style="padding: 40px 40px 20px 40px;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td align="center">
                    <!-- Logo Box -->
                    <div style="display: inline-block; width: 64px; height: 64px; background: linear-gradient(135deg, #fb923c 0%, #ec4899 50%, #d946ef 100%); border-radius: 16px; box-shadow: 0 10px 30px rgba(251, 146, 60, 0.3); margin-bottom: 16px; text-align: center; line-height: 64px; font-size: 32px; font-weight: bold; color: #0f172a; font-family: 'Inter', 'Noto Sans KR', 'Pretendard Variable', Arial, sans-serif;">
                      P
                    </div>
                    <!-- Brand Name -->
                    <h1 style="margin: 0; font-size: 28px; font-weight: 600; color: #ffffff; letter-spacing: -0.5px;">PickEat</h1>
                    <p style="margin: 4px 0 0 0; font-size: 12px; color: #94a3b8; letter-spacing: 0.1em; text-transform: uppercase;">Recommendation OS</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 0 40px 40px 40px;">
              <!-- Title -->
              <h2 style="margin: 0 0 16px 0; font-size: 24px; font-weight: 600; color: #ffffff; text-align: center;">
                {{emailTitle}}
              </h2>

              <!-- Personalized Greeting -->
              <p style="margin: 0 0 24px 0; font-size: 16px; line-height: 1.6; color: #cbd5e1; text-align: center;">
                Thank you for joining PickEat, <strong style="color: #ffffff;">{{userName}}</strong>!
              </p>

              <!-- Description -->
              <p style="margin: 0 0 32px 0; font-size: 14px; line-height: 1.6; color: #cbd5e1; text-align: center;">
                {{description}}
              </p>

              <!-- Features Section -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 auto 32px auto; background-color: rgba(15, 23, 42, 0.6); border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.1);">
                <tr>
                  <td style="padding: 32px 24px;">
                    <p style="margin: 0 0 20px 0; font-size: 14px; color: #94a3b8; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600; text-align: center;">{{featuresTitle}}</p>

                    <!-- Feature 1 -->
                    <p style="margin: 0 0 12px 0; font-size: 14px; line-height: 1.6; color: #cbd5e1;">
                      <strong style="color: #fb923c;">🤖 Personalized AI-Powered Menu Recommendations</strong><br>
                      <span style="color: #94a3b8;">Our AI analyzes your preferences to suggest the perfect meals for you.</span>
                    </p>

                    <!-- Feature 2 -->
                    <p style="margin: 0 0 12px 0; font-size: 14px; line-height: 1.6; color: #cbd5e1;">
                      <strong style="color: #ec4899;">🍽️ Diverse Restaurant Information</strong><br>
                      <span style="color: #94a3b8;">Discover nearby restaurants with comprehensive details at a glance.</span>
                    </p>

                    <!-- Feature 3 -->
                    <p style="margin: 0; font-size: 14px; line-height: 1.6; color: #cbd5e1;">
                      <strong style="color: #d946ef;">📍 Easy Address Management</strong><br>
                      <span style="color: #94a3b8;">Save your favorite locations and search them quickly.</span>
                    </p>
                  </td>
                </tr>
              </table>

              <!-- CTA Button -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 auto;">
                <tr>
                  <td align="center">
                    <a href="{{loginLink}}" style="display: inline-block; padding: 16px 48px; background: linear-gradient(135deg, #fb923c 0%, #ec4899 50%, #d946ef 100%); border-radius: 12px; text-decoration: none; font-size: 16px; font-weight: 600; color: #ffffff; box-shadow: 0 10px 30px rgba(251, 146, 60, 0.3);">
                      {{ctaText}}
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding: 24px 40px 40px 40px; border-top: 1px solid rgba(255, 255, 255, 0.1);">
              <p style="margin: 0 0 8px 0; font-size: 12px; color: #64748b; text-align: center;">
                {{footer}}
              </p>
              <p style="margin: 0 0 8px 0; font-size: 11px; color: #475569; text-align: center;">
                If you have any questions, please contact us at support@pickeat.com anytime.
              </p>
              <p style="margin: 16px 0 0 0; font-size: 11px; color: #64748b; text-align: center;">
                © 2025 PickEat. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
