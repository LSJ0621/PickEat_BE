<!DOCTYPE html>
<html lang="{{lang}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{pageTitle}}</title>
  <!--[if mso]>
  <style type="text/css">
    body, table, td {font-family: Arial, sans-serif !important;}
  </style>
  <![endif]-->
</head>
<body style="margin: 0; padding: 0; background-color: #FFFAF5; font-family: 'Pretendard Variable', 'Noto Sans KR', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #FFFAF5;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <!-- Main Container -->
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="max-width: 600px; background-color: #FFFFFF; border-radius: 12px; border: 1px solid #E5E5E5;">

          <!-- Header with Logo -->
          <tr>
            <td align="center" style="padding: 40px 40px 20px 40px;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td align="center">
                    <!-- Logo Box -->
                    <div style="display: inline-block; width: 64px; height: 64px; background-color: #FF6B35; border-radius: 16px; margin-bottom: 16px; text-align: center; line-height: 64px; font-size: 32px; font-weight: bold; color: #FFFFFF; font-family: 'Pretendard Variable', 'Noto Sans KR', Arial, sans-serif;">
                      P
                    </div>
                    <!-- Brand Name -->
                    <h1 style="margin: 0; font-size: 28px; font-weight: 600; color: #FF6B35; letter-spacing: -0.5px;">PickEat</h1>
                    <p style="margin: 4px 0 0 0; font-size: 12px; color: #8A8A8A; letter-spacing: 0.1em; text-transform: uppercase;">Recommendation OS</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 0 40px 40px 40px;">
              <!-- Title -->
              <h2 style="margin: 0 0 16px 0; font-size: 24px; font-weight: 600; color: #1A1A1A; text-align: center;">
                {{emailTitle}}
              </h2>

              <!-- Personalized Greeting -->
              <p style="margin: 0 0 24px 0; font-size: 16px; line-height: 1.6; color: #4A4A4A; text-align: center;">
                Thank you for joining PickEat, <strong style="color: #1A1A1A;">{{userName}}</strong>!
              </p>

              <!-- Description -->
              <p style="margin: 0 0 32px 0; font-size: 14px; line-height: 1.6; color: #4A4A4A; text-align: center;">
                {{description}}
              </p>

              <!-- Features Section -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 auto 32px auto; background-color: #FFF0E6; border-radius: 16px; border: 1px solid #E5E5E5;">
                <tr>
                  <td style="padding: 32px 24px;">
                    <p style="margin: 0 0 20px 0; font-size: 14px; color: #8A8A8A; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600; text-align: center;">{{featuresTitle}}</p>

                    <!-- Feature 1 -->
                    <p style="margin: 0 0 12px 0; font-size: 14px; line-height: 1.6; color: #4A4A4A;">
                      <strong style="color: #FF6B35;">🤖 Personalized AI-Powered Menu Recommendations</strong><br>
                      <span style="color: #8A8A8A;">Our AI analyzes your preferences to suggest the perfect meals for you.</span>
                    </p>

                    <!-- Feature 2 -->
                    <p style="margin: 0 0 12px 0; font-size: 14px; line-height: 1.6; color: #4A4A4A;">
                      <strong style="color: #FF6B35;">🍽️ Diverse Restaurant Information</strong><br>
                      <span style="color: #8A8A8A;">Discover nearby restaurants with comprehensive details at a glance.</span>
                    </p>

                    <!-- Feature 3 -->
                    <p style="margin: 0; font-size: 14px; line-height: 1.6; color: #4A4A4A;">
                      <strong style="color: #FF6B35;">📍 Easy Address Management</strong><br>
                      <span style="color: #8A8A8A;">Save your favorite locations and search them quickly.</span>
                    </p>
                  </td>
                </tr>
              </table>

              <!-- CTA Button -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 auto;">
                <tr>
                  <td align="center">
                    <a href="{{loginLink}}" style="display: inline-block; padding: 16px 48px; background-color: #FF6B35; border-radius: 12px; text-decoration: none; font-size: 16px; font-weight: 600; color: #ffffff;">
                      {{ctaText}}
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding: 24px 40px 40px 40px; border-top: 1px solid #E5E5E5;">
              <p style="margin: 0 0 8px 0; font-size: 12px; color: #8A8A8A; text-align: center;">
                {{footer}}
              </p>
              <p style="margin: 0 0 8px 0; font-size: 11px; color: #8A8A8A; text-align: center;">
                If you have any questions, please contact us at support@pickeat.com anytime.
              </p>
              <p style="margin: 16px 0 0 0; font-size: 11px; color: #8A8A8A; text-align: center;">
                © 2025 PickEat. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
