<!DOCTYPE html>
<html lang="{{lang}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{pageTitle}}</title>
  <!--[if mso]>
  <style type="text/css">
    body, table, td {font-family: Arial, sans-serif !important;}
  </style>
  <![endif]-->
</head>
<body style="margin: 0; padding: 0; background-color: #020617; font-family: 'Inter', 'Noto Sans KR', 'Pretendard Variable', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #020617;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <!-- Main Container -->
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="max-width: 600px; background-color: rgba(255, 255, 255, 0.05); border-radius: 32px; border: 1px solid rgba(255, 255, 255, 0.1); box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);">

          <!-- Header with Logo -->
          <tr>
            <td align="center" style="padding: 40px 40px 20px 40px;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td align="center">
                    <!-- Logo Box -->
                    <div style="display: inline-block; width: 64px; height: 64px; background: linear-gradient(135deg, #fb923c 0%, #ec4899 50%, #d946ef 100%); border-radius: 16px; box-shadow: 0 10px 30px rgba(251, 146, 60, 0.3); margin-bottom: 16px; text-align: center; line-height: 64px; font-size: 32px; font-weight: bold; color: #0f172a; font-family: 'Inter', 'Noto Sans KR', 'Pretendard Variable', Arial, sans-serif;">
                      P
                    </div>
                    <!-- Brand Name -->
                    <h1 style="margin: 0; font-size: 28px; font-weight: 600; color: #ffffff; letter-spacing: -0.5px;">PickEat</h1>
                    <p style="margin: 4px 0 0 0; font-size: 12px; color: #94a3b8; letter-spacing: 0.1em; text-transform: uppercase;">Recommendation OS</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 0 40px 40px 40px;">
              <!-- Title -->
              <h2 style="margin: 0 0 16px 0; font-size: 24px; font-weight: 600; color: #ffffff; text-align: center;">
                {{emailTitle}}
              </h2>

              <!-- User Greeting -->
              <p style="margin: 0 0 24px 0; font-size: 16px; line-height: 1.6; color: #cbd5e1; text-align: center;">
                Dear <strong style="color: #ffffff;">{{userName}}</strong>
              </p>

              <!-- Deactivation Notice -->
              <p style="margin: 0 0 32px 0; font-size: 14px; line-height: 1.6; color: #cbd5e1; text-align: center;">
                {{description}}
              </p>

              <!-- Deactivation Details Box -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 auto 32px auto; background-color: rgba(239, 68, 68, 0.1); border-radius: 16px; border: 1px solid rgba(239, 68, 68, 0.2);">
                <tr>
                  <td style="padding: 32px 24px;">
                    <p style="margin: 0 0 12px 0; font-size: 11px; color: #fca5a5; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 500; text-align: center;">Deactivation Details</p>

                    <!-- Deactivation Time -->
                    <p style="margin: 0 0 16px 0; font-size: 14px; line-height: 1.6; color: #fecaca; text-align: center;">
                      <strong style="color: #fef2f2;">Deactivated At:</strong><br>
                      {{deactivatedAt}}
                    </p>

                    <!-- Reason -->
                    <p style="margin: 0; font-size: 14px; line-height: 1.6; color: #fecaca; text-align: center;">
                      <strong style="color: #fef2f2;">Reason:</strong><br>
                      {{{reason}}}
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Reactivation Info -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 auto 32px auto; background-color: rgba(15, 23, 42, 0.6); border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.1);">
                <tr>
                  <td style="padding: 24px 24px;">
                    <p style="margin: 0 0 16px 0; font-size: 14px; color: #94a3b8; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600; text-align: center;">Reactivation Information</p>

                    <p style="margin: 0 0 12px 0; font-size: 14px; line-height: 1.6; color: #cbd5e1;">
                      <strong style="color: #fb923c;">📧 Contact Customer Support</strong><br>
                      <span style="color: #94a3b8;">To request account reactivation, please contact us at the email below.</span>
                    </p>

                    <p style="margin: 0 0 16px 0; font-size: 14px; line-height: 1.6; color: #cbd5e1; text-align: center;">
                      <a href="mailto:{{supportEmail}}" style="color: #ec4899; text-decoration: none; font-weight: 600;">{{supportEmail}}</a>
                    </p>

                    <p style="margin: 0; font-size: 14px; line-height: 1.6; color: #cbd5e1;">
                      <strong style="color: #d946ef;">⏰ Data Retention Policy</strong><br>
                      <span style="color: #94a3b8;">Account data will be retained for <strong style="color: #ffffff;">{{dataRetentionDays}} days</strong> after deactivation.</span>
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Info Box -->
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 auto; background-color: rgba(251, 146, 60, 0.1); border-radius: 12px; border: 1px solid rgba(251, 146, 60, 0.2);">
                <tr>
                  <td style="padding: 16px 20px;">
                    <p style="margin: 0; font-size: 12px; line-height: 1.6; color: #fed7aa; text-align: center;">
                      ℹ️ If you have any questions about this email, please contact our customer support team.
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding: 24px 40px 40px 40px; border-top: 1px solid rgba(255, 255, 255, 0.1);">
              <p style="margin: 0 0 8px 0; font-size: 12px; color: #64748b; text-align: center;">
                {{footer}}
              </p>
              <p style="margin: 16px 0 0 0; font-size: 11px; color: #64748b; text-align: center;">
                © 2025 PickEat. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
