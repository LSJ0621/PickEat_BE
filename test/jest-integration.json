{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "roots": ["<rootDir>/test/integration"],
  "testEnvironment": "node",
  "testRegex": ".*\\.integration\\.spec\\.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1",
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "setupFiles": ["<rootDir>/test/jest-env-setup.ts"],
  "setupFilesAfterEnv": ["<rootDir>/test/jest-setup.ts"],
  "testTimeout": 30000,
  "maxWorkers": 1,
  "collectCoverageFrom": [
    "src/**/*.(t|j)s",
    "!src/**/*.spec.ts",
    "!src/**/*.interface.ts",
    "!src/**/*.dto.ts",
    "!src/**/*.module.ts",
    "!src/**/*.entity.ts",
    "!src/**/*.enum.ts",
    "!src/**/*.constants.ts",
    "!src/**/config/**",
    "!src/main.ts",
    "!src/common/services/db-metrics.service.ts",
    "!src/prometheus/**",
    "!src/**/__tests__/**"
  ],
  "coverageDirectory": "coverage-integration",
  "coverageReporters": ["text", "lcov", "html"],
  "coverageThreshold": {
    "global": {
      "branches": 20,
      "functions": 30,
      "lines": 30,
      "statements": 30
    }
  }
}
