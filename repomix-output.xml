  @IsString()
  @IsNotEmpty()
  EMAIL_SECURE: string;

  @IsString()
  @IsNotEmpty()
  EMAIL_ADDRESS: string;

  @IsString()
  @IsNotEmpty()
  EMAIL_PASSWORD: string;

  // OpenAI
  @IsString()
  @IsNotEmpty()
  OPENAI_API_KEY: string;

  @IsString()
  @IsNotEmpty()
  OPENAI_MODEL: string;

  @IsString()
  @IsNotEmpty()
  OPENAI_MENU_MODEL: string;

  @IsString()
  @IsNotEmpty()
  OPENAI_PREFERENCE_MODEL: string;

  @IsString()
  @IsNotEmpty()
  OPENAI_PLACES_MODEL: string;

  // Kakao API
  @IsString()
  @IsNotEmpty()
  KAKAO_REST_API_KEY: string;

  @IsString()
  @IsNotEmpty()
  OAUTH_KAKAO_CLIENT_ID: string;

  @IsString()
  @IsNotEmpty()
  OAUTH_KAKAO_REDIRECT_URI: string;

  // Google API
  @IsString()
  @IsNotEmpty()
  GOOGLE_API_KEY: string;

  @IsString()
